{
  "compilerOptions": {
 "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*", "src/types/*"]
    },

    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}